{
  "name": "openeyes-backend",
  "version": "1.0.0",
  "description": "openEyes 后端服务和 CLI 工具",
  "main": "dist/index.js",
  "bin": {
    "openeyes": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev:cli": "tsx src/cli/index.ts",
