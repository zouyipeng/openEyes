  "dependencies": {
    "@prisma/client": "5",
    "axios": "^1.6.0",
    "cheerio": "^1.0.0",
    "commander": "^12.0.0",
    "cors": "^2.8.5",
    "express": "^4.18.0",
    "node-cron": "^3.0.3",
    "openai": "^4.0.0",
    "prisma": "5",
    "rss-parser": "^3.13.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.0.0",
    "@types/node-cron": "^3.0.11",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
